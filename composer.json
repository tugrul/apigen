{
    "name": "tugrul/apigen",
    "version": "1.0.0",
    "description": "Generate REST API SDK libraries from annotated PHP interfaces. PSR-18 based, attribute-driven.",
    "type": "library",
    "license": "MIT",
    "keywords": ["rest", "api", "sdk", "generator", "psr-18", "attributes", "php8"],
    "require": {
        "php": ">=8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "nyholm/psr7": "^1.8",
        "psr/simple-cache": "^3.0"
    },
    "suggest": {
        "psr/simple-cache": "Required to use Psr16TokenCache for Redis/Memcached/APCu token storage"
    },
    "autoload": {
        "psr-4": {
            "Tugrul\\ApiGen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tugrul\\ApiGen\\Tests\\": "tests/",
            "MyApp\\": "examples/"
        }
    },
    "bin": [ "bin/apigen" ],
    "scripts": {
        "test":         "phpunit",
        "test:unit":    "phpunit --testsuite=Unit",
        "test:coverage": "phpunit --coverage-text",
        "generate": "bin/apigen generate"
    },
    "config": {
        "sort-packages": true
    }
}
